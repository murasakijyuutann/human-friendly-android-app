<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:title="@string/drawing_title"
        app:titleTextColor="?attr/colorOnPrimary"
        android:background="?attr/colorPrimary"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- Color & action buttons -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/drawing_color"
                android:layout_marginEnd="8dp"
                android:textAppearance="?attr/textAppearanceBodySmall" />

            <!-- Color buttons -->
            <View
                android:id="@+id/colorBlack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/color_circle_black"
                android:tooltipText="@string/color_black"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/colorRed"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/color_circle_red"
                android:tooltipText="@string/color_red"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/colorBlue"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/color_circle_blue"
                android:tooltipText="@string/color_blue"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/colorWhite"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/color_circle_white"
                android:tooltipText="@string/color_white"
                android:clickable="true"
                android:focusable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/drawing_clear"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/drawing_save" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Drawing canvas -->
    <com.example.noteapp.ui.notes.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF" />

</LinearLayout>

    <!-- Color name popup label shown on long press near the touched color icon -->
    <TextView
        android:id="@+id/colorNameLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:visibility="gone" />

</FrameLayout>
